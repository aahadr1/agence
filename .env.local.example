# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Replicate
REPLICATE_API_TOKEN=r8_your_replicate_api_token

# Tavily (web search for AI)
TAVILY_API_KEY=tvly-your_tavily_api_key

# Twilio (téléphonie — voir docs/TELEPHONY.md)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TRANSFER_TO_BOSS=
# Numéro affiché au client (Verified Caller ID) — optionnel
# TWILIO_CALLER_ID=
# Transcription des enregistrements d’appel (Gemini)
GEMINI_API_KEY=
# Google PageSpeed Insights API (free, 25k req/day) — https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
PAGESPEED_API_KEY=
# Pappers.fr company registry API (free, 10k req/month) — https://www.pappers.fr/api
# Returns owner name, SIREN, legal form, employee count, creation date for French businesses.
PAPPERS_API_KEY=
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# TWILIO_WEBHOOK_BASE_URL=https://your-domain.com
# SKIP_TWILIO_SIGNATURE_VALIDATION=true

# Inngest (legacy — Lead Agent v2. Agent v3 uses its own built-in runtime)
# You can safely leave these empty; the new tick-based runtime replaces Inngest.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Set to 1 for local dev without Inngest Cloud
# INNGEST_DEV=1

# Upstash Redis (Lead Agent v2 — caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Lead Agent v2 — Contact enrichment APIs (optional, adds capabilities)
# DROPCONTACT_API_KEY=
# HUNTER_API_KEY=
# KASPR_API_KEY=
# LUSHA_API_KEY=
# CAPTAIN_VERIFY_API_KEY=
# PHANTOMBUSTER_API_KEY=
# GOOGLE_PLACES_API_KEY=

# ─────────────────────────────────────────────────────────────
# Agent v3 (autonomous multi-model agent)
# ─────────────────────────────────────────────────────────────

# Anthropic (optional — Gemini is used by default since we have more quota there)
# Only needed if you want to select Claude models in the UI.
ANTHROPIC_API_KEY=

# Google OAuth (Gmail + Calendar integration)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (type: Web application)
# 3. Authorized redirect URIs: https://your-domain.com/api/integrations/google/callback
# 4. Enable APIs: Gmail API, Google Calendar API, People API (for userinfo)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Leave empty to auto-derive from NEXT_PUBLIC_APP_URL
GOOGLE_OAUTH_REDIRECT_URL=

# Encryption key for OAuth tokens at rest (REQUIRED in production).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────
# Agent v3 autonomous runtime (DIY — replaces Inngest)
# ─────────────────────────────────────────────────────────────

# Secret shared between the agent runtime and itself when self-chaining ticks.
# Optional in dev. In production, set to a random 32+ char string.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_TICK_SECRET=

# Secret for Vercel Cron jobs hitting /api/agent/cron/recover.
# If unset, the cron route is unauthenticated (fine for a private deploy).
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
# Agent self-coding pack — lets the agent extend itself via GitHub PRs
# ─────────────────────────────────────────────────────────────
#
# KILL SWITCH. Must be literally "true" to enable the self-coding tool pack.
# If unset (default), the repo_* tools are not registered and the agent
# cannot touch the repository.
AGENT_SELF_CODING=false

# GitHub target repo. The agent opens PRs against GITHUB_BASE_BRANCH of
# GITHUB_OWNER/GITHUB_REPO. Use a fine-grained PAT scoped to this repo only,
# with contents:write + pull_requests:write + checks:read.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
# Defaults to "main" if unset.
GITHUB_BASE_BRANCH=main

# Rate limit — how many self-coding PRs per org per rolling hour (default 10).
AGENT_MAX_COMMITS_PER_HOUR=10
