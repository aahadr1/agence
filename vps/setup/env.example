# /etc/opencode.env — variables d'environnement chargées par les services systemd.
# Copie ce fichier vers /etc/opencode.env et remplis les valeurs.

# ─── Modèle (DeepSeek V3.x) ──────────────────────────────────────────────────
# https://platform.deepseek.com → API keys
DEEPSEEK_API_KEY=

# ─── Auth serveur OpenCode (Basic Auth derrière Caddy) ───────────────────────
# Génère avec : openssl rand -base64 32
OPENCODE_SERVER_PASSWORD=
OPENCODE_SERVER_USERNAME=aaron

# ─── Reverse-proxy / TLS ─────────────────────────────────────────────────────
# Sous-domaine pointant vers ton VPS (DNS A record). Vide = pas de TLS public.
# Ex: opencode.agence.fr
OPENCODE_PUBLIC_HOSTNAME=

# ─── Telegram bot ────────────────────────────────────────────────────────────
# 1. Crée un bot via @BotFather → /newbot → copie le token
# 2. Récupère ton ID via @userinfobot → /start
TELEGRAM_BOT_TOKEN=
# IDs Telegram autorisés (séparés par virgule). Personne d'autre ne pourra parler au bot.
TELEGRAM_ALLOWED_USER_IDS=

# ─── Supabase (lecture/écriture leads, clients CRM) ──────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# UUID auth.users de l’utilisateur propriétaire des leads (Dashboard → Auth → Users)
AGENT_USER_ID=

# ─── APIs externes (lead-gen) ────────────────────────────────────────────────
# Pappers — gratuit jusqu'à 10k req/mois — https://www.pappers.fr/api
PAPPERS_API_KEY=
# Société.com API PRO (besoin d'allowlist IP probable)
SOCIETE_API_KEY=
# Google PageSpeed Insights — gratuit 25k req/jour
PAGESPEED_API_KEY=
# Gemini (optionnel — analyse de screenshots)
GEMINI_API_KEY=
